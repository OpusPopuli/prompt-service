    {
      "name": "Admin - Node Registry",
      "description": "Node registration, certification lifecycle, and health monitoring. Require admin API key.",
      "item": [
        {
          "name": "Register Node",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Node created with API key', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('apiKey');",
                  "  pm.collectionVariables.set('nodeId', body.id);",
                  "  pm.collectionVariables.set('nodeApiKey', body.apiKey);",
                  "  pm.environment.set('nodeId', body.id);",
                  "  pm.environment.set('nodeApiKey', body.apiKey);",
                  "  console.log('Saved nodeId: ' + body.id);",
                  "  console.log('Saved nodeApiKey: ' + body.apiKey.substring(0, 8) + '...');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"node-ca-01\",\n  \"region\": \"ca\",\n  \"publicKey\": \"optional-public-key-for-signature-verification\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/admin/nodes", "host": ["{{baseUrl}}"], "path": ["admin", "nodes"] }
          }
        },
        {
          "name": "List Nodes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
